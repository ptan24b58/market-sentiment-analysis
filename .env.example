#
# Copy to .env and fill in. Do NOT commit .env.
#

# AWS Bedrock (Nova Lite) — required for persona pipeline and zero-shot baseline
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Bedrock model selection — primary is Nova Lite; fallback is Llama 3.1 8B
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_FALLBACK_MODEL_ID=meta.llama3-1-8b-instruct-v1:0

# Optional: Mapbox token for the choropleth UI
# If empty, UI falls back to local OSM tiles (pre-cached via ui/scripts/prefetch-tiles.sh)
MAPBOX_TOKEN=

# Optional: override default persona count (300 default; drop to 150 if Bedrock throttles)
PERSONA_COUNT=300

# Optional: log level for the pipeline
LOG_LEVEL=INFO

# Optional: set to 1 to enable real Bedrock calls in integration tests (normally mocked)
# BEDROCK_LIVE_TESTS=0
